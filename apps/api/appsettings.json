{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=browser-agent-postgres;Port=5432;Database=browser_agent;Username=browser_agent;Password=browser_agent"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AIService": {
    "BaseUrl": "http://browser-agent-ai:8000"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_USE_A_SECURE_KEY_IN_PRODUCTION",
    "Issuer": "browser-agent-api",
    "Audience": "browser-agent-web",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Storage": {
    "LocalPath": "/app/storage"
  },
  "Encryption": {
    "Key": ""
  },
  "Cors": {
    "Origins": "http://browser-agent-web:5173"
  }
}
