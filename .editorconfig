root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{json,yaml,yml}]
indent_size = 2

[*.{js,jsx,ts,tsx,css,html}]
indent_size = 2

[*.{cs,csproj,sln}]
indent_style = space
indent_size = 4

[*.{py,pyproject.toml}]
indent_size = 4

[Dockerfile]
indent_size = 4
